{
  "type": "工程感网络拓扑图",
  "goal": "生成一张企业级 SD-WAN 逻辑拓扑位图，含 Internet、MPLS、各站点 CPE、中心汇聚防火墙与 orchestrator、以及上云专线的加密隧道（IPsec/BGP 标注），大框表示站点与安全域",
  "canvas": {
    "aspect_ratio": "16:9",
    "background": "deep slate #0F172A with subtle 1px grid #1E293B at 32px spacing",
    "outer_padding": "60px"
  },
  "title_strip": {
    "title": "Aurora Retail SD-WAN 总部-分支-云 一体拓扑",
    "subtitle": "MPLS + 双互联网 + 云专线 · BGP ASN 65001",
    "position": "top-left, JetBrains Mono / SF Mono, light gray"
  },
  "device_glyphs": {
    "rule": "router=菱形内叉、firewall=砖墙、cloud=简笔云+文字 CPE/ctrl",
    "types": [
      {
        "type": "router",
        "glyph": "diamond with X",
        "color": "amber #FBBF24"
      },
      {
        "type": "firewall",
        "glyph": "brick wall",
        "color": "rose #FB7185"
      },
      {
        "type": "switch",
        "glyph": "rect multiple bottom ports",
        "color": "amber #FBBF24"
      },
      {
        "type": "server",
        "glyph": "rack 3-4 槽",
        "color": "emerald #34D399"
      },
      {
        "type": "cloud_service",
        "glyph": "cloud with text",
        "color": "cyan #22D3EE"
      },
      {
        "type": "user",
        "glyph": "stick figure",
        "color": "cyan #22D3EE"
      }
    ]
  },
  "zones": {
    "count": 4,
    "items": [
      {
        "id": "Z1",
        "label": "总部 DC 核心 · VLAN10/20 汇聚",
        "color_border": "amber #FBBF24 dashed",
        "cidr": "172.20.0.0/16"
      },
      {
        "id": "Z2",
        "label": "上海门店 · CPE-3000",
        "color_border": "blue #60A5FA dashed",
        "cidr": "10.30.0.0/20"
      },
      {
        "id": "Z3",
        "label": "深圳 R&D 实验室",
        "color_border": "emerald #34D399 dashed",
        "cidr": "10.40.0.0/20"
      },
      {
        "id": "Z4",
        "label": "云托管区 (VPN/DX 落地)",
        "color_border": "violet #A78BFA dashed",
        "cidr": "10.200.0.0/20"
      }
    ]
  },
  "nodes": {
    "items": [
      {
        "id": "N1",
        "type": "router",
        "label": "HQ 边界路由器 A\\n(BGP 65001)",
        "zone": "Z1"
      },
      {
        "id": "N2",
        "type": "router",
        "label": "HQ 边界路由器 B (HRP)",
        "zone": "Z1"
      },
      {
        "id": "N3",
        "type": "firewall",
        "label": "双机防火墙集群\\n(南北向、IPS ON)",
        "zone": "Z1"
      },
      {
        "id": "N4",
        "type": "switch",
        "label": "核心交换\\n(MLAG)",
        "zone": "Z1"
      },
      {
        "id": "N5",
        "type": "server",
        "label": "SD-WAN 控制器 (on-prem)\n+ 管理平面",
        "zone": "Z1"
      },
      {
        "id": "N6",
        "type": "router",
        "label": "门店 CPE 上海 (双上行)",
        "zone": "Z2"
      },
      {
        "id": "N7",
        "type": "user",
        "label": "POS/扫码枪终端 (终端 TLS 1.2)",
        "zone": "Z2"
      },
      {
        "id": "N8",
        "type": "router",
        "label": "深圳 CPE 实验室",
        "zone": "Z3"
      },
      {
        "id": "N9",
        "type": "cloud_service",
        "label": "企业云 VPC 网关/ VPN Hub\\n(汇聚 IPsec, BGP over tunnel)",
        "zone": "Z4"
      }
    ],
    "node_label_format": "双行，上面角色下面协议/AS，mono 10pt"
  },
  "connections": {
    "items": [
      {
        "from": "N1",
        "to": "N3",
        "type": "physical",
        "label": "10Gbps 内网·静态路由"
      },
      {
        "from": "N2",
        "to": "N3",
        "type": "physical",
        "label": "10Gbps 内网·静态路由"
      },
      {
        "from": "N3",
        "to": "N4",
        "type": "physical",
        "label": "L3 到核心"
      },
      {
        "from": "N1",
        "to": "N6",
        "type": "encrypted",
        "label": "MPLS L3VPN 标签交换 + SD-WAN overlay"
      },
      {
        "from": "N1",
        "to": "N6",
        "type": "redundant",
        "label": "Internet DTLS 备链路 300Mbps"
      },
      {
        "from": "N2",
        "to": "N8",
        "type": "encrypted",
        "label": "MPLS + 互联网混合选路"
      },
      {
        "from": "N5",
        "to": "N6",
        "type": "logical",
        "label": "控制/策略下发 Netconf/HTTPS"
      },
      {
        "from": "N5",
        "to": "N8",
        "type": "logical",
        "label": "控制/策略下发"
      },
      {
        "from": "N4",
        "to": "N9",
        "type": "encrypted",
        "label": "IPsec 隧道 + eBGP 65001-65555"
      },
      {
        "from": "N7",
        "to": "N6",
        "type": "physical",
        "label": "门店 LAN 1G"
      },
      {
        "from": "N6",
        "to": "N4",
        "type": "encrypted",
        "label": "业务回总部 DC 的优选路径"
      }
    ],
    "line_style": {
      "physical": "solid 2px slate #94A3B8",
      "logical": "dashed 1.5px slate #64748B",
      "redundant": "双 violet 平行线 表示双上行",
      "encrypted": "emerald 2px + 锁 glyph 表示国密/ IPSec 可选注记"
    }
  },
  "annotations": {
    "ip_cidr_labels": {
      "enabled": true,
      "rule": "Z1~Z4 显式写 CIDR；隧道端点可写公网/33 位"
    },
    "az_labels": {
      "enabled": false,
      "rule": "非云多 AZ 场景，关闭 AZ 标，可改标 city code"
    }
  },
  "legend": {
    "enabled": true,
    "position": "bottom-right",
    "content": "router/防火墙/CPE/server glyph；MPLS 与互联网双上行样式；IPsec+BGP 上云；logical 为灰虚线",
    "style": "small panel, mono 10pt"
  },
  "constraints": {
    "must_keep": [
      "站点用虚线大框+ CIDR",
      "MPLS 与 internet 以不同线型/平行双线区分",
      "加密跨域链路带锁或 'IPsec' 小字"
    ],
    "avoid": [
      "Cisco/华为 官方产品剪影",
      "未标注速率的广域网粗线"
    ]
  }
}
