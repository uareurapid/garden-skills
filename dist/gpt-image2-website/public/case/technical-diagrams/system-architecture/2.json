{
  "type": "技术系统架构图（暗色工程感）",
  "goal": "生成一张 618 大促期秒杀与下单链路的总览位图，强调 CDN/边缘、业务微服务、消息与数据层的分层，以及主从与缓存的职责边界",
  "canvas": {
    "aspect_ratio": "16:9",
    "background": "deep slate #0F172A with subtle 1px grid lines #1E293B at 32px spacing",
    "outer_padding": "60px"
  },
  "title_strip": {
    "title": "NimbusMart 电商 · 秒杀下单 · 技术架构",
    "subtitle": "sharded + cache-aside + async settle · 华东生产",
    "position": "top-left, large mono font (JetBrains Mono / SF Mono), light gray text"
  },
  "color_semantics": {
    "rule": "颜色按'角色'编码，不按'技术'编码",
    "palette": [
      {
        "role": "User / Client / Edge",
        "color": "cyan #22D3EE",
        "use_for": "终端用户、Web、Mobile、CLI"
      },
      {
        "role": "Gateway / API / BFF",
        "color": "blue #60A5FA",
        "use_for": "API 网关、负载均衡、CDN、BFF"
      },
      {
        "role": "Business Services",
        "color": "emerald #34D399",
        "use_for": "微服务、应用层、业务逻辑"
      },
      {
        "role": "Data / Persistence",
        "color": "violet #A78BFA",
        "use_for": "数据库、缓存、对象存储、搜索"
      },
      {
        "role": "Middleware / Queue",
        "color": "orange #FB923C",
        "use_for": "MQ、Kafka、Redis Stream、Pub/Sub"
      },
      {
        "role": "Infra / Platform",
        "color": "amber #FBBF24",
        "use_for": "K8s、容器运行时、云平台"
      },
      {
        "role": "Security / Auth",
        "color": "rose #FB7185",
        "use_for": "鉴权、密钥、审计、防火墙"
      },
      {
        "role": "External / 3rd Party",
        "color": "slate #94A3B8",
        "use_for": "外部 SaaS、第三方 API"
      }
    ]
  },
  "regions": {
    "rule": "用大虚线框包围属于同一'部署单元'的节点，框上方有 region label",
    "items": [
      {
        "id": "R1",
        "label": "Edge · CDN 与 L7 入口",
        "color_border": "cyan dashed"
      },
      {
        "id": "R2",
        "label": "Service Mesh · 订单 / 库存 / 支付",
        "color_border": "emerald dashed"
      },
      {
        "id": "R3",
        "label": "Data · 主从、缓存、消息",
        "color_border": "violet dashed"
      }
    ]
  },
  "nodes": {
    "count_total": 12,
    "items": [
      {
        "id": "N1",
        "label": "顾客终端 (H5/小程序)",
        "role": "User / Client / Edge",
        "region": "R1"
      },
      {
        "id": "N2",
        "label": "阿里云 CDN (静态 + 防刷)",
        "role": "Gateway / API / BFF",
        "region": "R1"
      },
      {
        "id": "N3",
        "label": "Nginx + OpenResty (limit_req)",
        "role": "Gateway / API / BFF",
        "region": "R1"
      },
      {
        "id": "N4",
        "label": "Order Service",
        "role": "Business Services",
        "region": "R2"
      },
      {
        "id": "N5",
        "label": "Inventory Service",
        "role": "Business Services",
        "region": "R2"
      },
      {
        "id": "N6",
        "label": "Payment Service",
        "role": "Business Services",
        "region": "R2"
      },
      {
        "id": "N7",
        "label": "Risk Engine (反作弊)",
        "role": "Security / Auth",
        "region": "R2"
      },
      {
        "id": "N8",
        "label": "RabbitMQ (order.exchange)",
        "role": "Middleware / Queue",
        "region": "R3"
      },
      {
        "id": "N9",
        "label": "Redis Cluster (库存热点)",
        "role": "Data / Persistence",
        "region": "R3"
      },
      {
        "id": "N10",
        "label": "MySQL 8 主",
        "role": "Data / Persistence",
        "region": "R3"
      },
      {
        "id": "N11",
        "label": "MySQL 8 从 (只读)",
        "role": "Data / Persistence",
        "region": "R3"
      },
      {
        "id": "N12",
        "label": "微信支付网关回调入口",
        "role": "External / 3rd Party",
        "region": "R1"
      }
    ]
  },
  "node_style": {
    "shape": "rounded rectangle, corner radius 8px",
    "size": "auto-fit text + 24px horizontal padding, ~ 140px wide × 56px tall typical",
    "fill": "background color of role × 12% opacity (semi-transparent)",
    "border": "1.5px solid in role color (full opacity)",
    "label": "label text in JetBrains Mono / SF Mono 12pt, color = role color (lighter shade) for readability on dark bg",
    "icon": "small icon in top-left corner of node (optional, generic geometric glyph for the role — circle for service, cylinder for DB, hex for queue)"
  },
  "edges": {
    "items": [
      {
        "from": "N1",
        "to": "N2",
        "style": "sync",
        "label": "HTTPS"
      },
      {
        "from": "N2",
        "to": "N3",
        "style": "sync",
        "label": "回源"
      },
      {
        "from": "N3",
        "to": "N4",
        "style": "sync",
        "label": "POST /v1/orders"
      },
      {
        "from": "N4",
        "to": "N7",
        "style": "sync",
        "label": "score"
      },
      {
        "from": "N4",
        "to": "N5",
        "style": "sync",
        "label": "reserve"
      },
      {
        "from": "N5",
        "to": "N9",
        "style": "sync",
        "label": "DECR stock:{sku}"
      },
      {
        "from": "N4",
        "to": "N8",
        "style": "async",
        "label": "order.created"
      },
      {
        "from": "N8",
        "to": "N6",
        "style": "async",
        "label": "pay.task"
      },
      {
        "from": "N4",
        "to": "N10",
        "style": "sync",
        "label": "INSERT orders"
      },
      {
        "from": "N5",
        "to": "N10",
        "style": "sync",
        "label": "行锁扣减"
      },
      {
        "from": "N6",
        "to": "N10",
        "style": "sync",
        "label": "UPDATE pay_status"
      },
      {
        "from": "N11",
        "to": "N4",
        "style": "sync",
        "label": "SELECT 订单快照"
      },
      {
        "from": "N12",
        "to": "N3",
        "style": "async",
        "label": "notify_url POST"
      }
