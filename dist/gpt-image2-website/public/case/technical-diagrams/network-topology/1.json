  "legend": {
    "enabled": true,
    "position": "bottom-right",
    "content": "glyph 类型、physical vs logical/encrypted 线、zone 边框色",
    "style": "small panel, mono 10pt"
  },
  "constraints": {
    "must_keep": [
      "大虚线框分 Internet / VPC / 子网",
